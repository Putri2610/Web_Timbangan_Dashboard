private static function addAttribute($dom, $elementType, $name, $type, $maxLength)
{
    $attribute = $dom->createElement('s:AttributeType');
    $attribute->setAttribute('name', $name);
    $attribute->setAttribute('rs:number', '1');
    $attribute->setAttribute('rs:nullable', 'true');
    $attribute->setAttribute('rs:write', 'true');

    $datatype = $dom->createElement('s:datatype');
    $datatype->setAttribute('dt:type', $type);

    if ($type == 'string') {
        $datatype->setAttribute('rs:dbtype', 'str');
    }

    $datatype->setAttribute('dt:maxLength', $maxLength);
    $datatype->setAttribute('rs:precision', '0');

    $attribute->appendChild($datatype);

    $elementType->appendChild($attribute);
}

